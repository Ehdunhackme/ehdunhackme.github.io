@inproceedings{ramasethu2026linguistically,
  abbr      = {LoResMT},
  title     = {Can Linguistically Related Languages Guide {LLM} Translation in Low-Resource Settings?},
  author    = {Ramasethu, Aishwarya and Garg, Rohin and Allu, Niyathi and Fartale, Harshwardhan and Chan, Dun Li},
  booktitle = {Proceedings of the Ninth Workshop on Technologies for Machine Translation of Low Resource Languages (LoResMT 2026)},
  pages     = {168--185},
  year      = {2026},
  month     = {March},
  url       = {https://aclanthology.org/2026.loresmt-1.14},
  html      = {https://aclanthology.org/2026.loresmt-1.14},
  arxiv     = {2603.16660},
  selected  = {true},
  abstract  = {Large Language Models (LLMs) have achieved strong performance across many downstream tasks, yet their effectiveness in extremely low-resource machine translation remains limited. Standard adaptation techniques typically rely on large-scale parallel data or extensive fine-tuning, which are infeasible for the long tail of underrepresented languages. In this work, we investigate a more constrained question: in data-scarce settings, to what extent can linguistically similar pivot languages and few-shot demonstrations provide useful guidance for on-the-fly adaptation in LLMs?}
}

@inproceedings{cahyawijaya2026anthropogenic,
  abbr      = {ECCV},
  title     = {Anthropogenic Regional Adaptation in Multimodal Vision-Language Model},
  author    = {Cahyawijaya, Samuel and Limkonchotiwat, Peerat and Wong, Tack Hwa and Patel, Hitesh Laxmichand and Agarwal, Amit and Rufino, Manuel Antonio and Catalan, Carlos Rafael and Qorib, Muhammad Reza and Feliren, Vicky and Lovenia, Holy and Khine, Aye Hninn and Hudi, Frederikus and Anugraha, David and Aji, Alham Fikri and Chumpu, Romrawin and Pham, Viet-Thanh and Wang, Minghan and Imam, Mohamed Fazli and Zhang, Ruochen and Imperial, Joseph Marvin and Long, Do Xuan and Wijanarko, Musa Izzanardi and Moniz, Joel Ruben Antony and Irawan, Patrick Amadeus and Zhafran, Hanif Muhammad and Flores, Isaiah and Salsabila, Ira and Kevin, Jun and Rosal, Jostin Jerico and Monderin, Patricia Nicole and Kerdthaisong, Kun and Mustafid, Ahmad and Nguyen, My Chiffon and Jongwiriyanurak, Natchapon and Worajitwannakul, Siva and Li, Haochen and Lim, Adrian Xuan Wei and Wang, Bin and Habibi, Muhammad Ravi Shulthan and Ng, Lynnette Hui Xian and Bangera, Mithil and Bangera, Yeshil and Pattnayak, Priyaranjan and Chan, Dun Li and Djuniwar, Sherissa Caren and Shan, Hee Ming},
  booktitle = {Proceedings of the European Conference on Computer Vision (ECCV)},
  year      = {2026},
  arxiv     = {2604.11490},
  selected  = {true},
  abstract  = {While the field of vision-language (VL) has achieved remarkable success in integrating visual and textual information across multiple languages and domains, there is still no dedicated framework for assessing human-centric alignment in vision-language systems. We introduce Anthropogenic Regional Adaptation: a novel paradigm that aims to optimize model relevance to specific regional contexts while ensuring the retention of global generalization capabilities, and present GG-EZ, a simple but effective adaptation method utilizing regional data filtering and model merging.}
}

@inproceedings{zhouzhen2025traditional,
  abbr      = {ISMIR},
  title     = {A Traditional Approach to Symbolic Piano Continuation},
  author    = {Zhou-Zheng, Christian and Backsund, John and Chan, Dun Li and Coventry, Alex and Eslami, Avid and Goel, Jyotin and Han, Xingwen and Soomro, Danysh and Wei, Galen},
  booktitle = {Music Information Retrieval Evaluation eXchange (MIREX 2025), International Society for Music Information Retrieval Conference (ISMIR)},
  year      = {2025},
  arxiv     = {2509.12267},
  selected  = {true},
  abstract  = {We present a traditional approach to symbolic piano music continuation for the MIREX 2025 Symbolic Music Generation challenge. While computational music generation has recently focused on developing large foundation models with sophisticated architectural modifications, we argue that simpler approaches remain more effective for constrained, single-instrument tasks.}
}